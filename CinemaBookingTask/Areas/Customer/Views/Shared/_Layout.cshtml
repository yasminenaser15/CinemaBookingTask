<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Cinema Booking</title>

    <link href="~/customer/bootstrap/css/bootstrap.css" rel="stylesheet" />
    <link href="~/customer/animate.css/animate.css" rel="stylesheet" />
    <link href="~/customer/fontawesome/css/fontawesome-all.css" rel="stylesheet" />
    <link href="~/customer/magnific-popup/magnific-popup.css" rel="stylesheet" />
    <link href="~/customer/slick/slick.css" rel="stylesheet" />
    <link href='https://fonts.googleapis.com/css?family=Oswald:300,400,500,700' rel='stylesheet'>
    <link href='https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700' rel='stylesheet'>
    <link href="~/customer/css/dot-icons.css" rel="stylesheet">
    <link href="~/customer/css/theme.css" rel="stylesheet">
</head>
<body class="body">

    <header class="header header-horizontal header-view-pannel">
        <div class="container">
            <nav class="navbar">
                <a class="navbar-brand" href="/Customer/Home/Index">
                    <span class="logo-element">
                        <span class="logo-tape"></span>
                        <span class="logo-text text-uppercase">
                            <span>C</span>inema
                        </span>
                    </span>
                </a>
                <button class="navbar-toggler" type="button">
                    <span class="th-dots-active-close th-dots th-bars">
                        <span></span><span></span><span></span>
                    </span>
                </button>
                <div class="navbar-collapse">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="/Customer/Home/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Movie/Index">Movies</a>
                        </li>
                    </ul>
                    <div class="navbar-extra">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="text-white me-3">
                                Hello, @User.Identity.Name
                            </span>

                            <a asp-controller="Account"
                                   asp-action="Logout"
                                   asp-area="Customer"
                                   class="btn btn-outline-dark rounded-pill px-4">
                                Logout
                            </a>
                        }
                        else
                        {
                            <div class="mt-4 d-flex gap-3 flex-wrap">

                                <a asp-controller="Account"
                                       asp-action="Register"
                                       asp-area="Customer"
                                       class="btn btn-outline-primary rounded-pill px-4">
                                    Register
                                </a>

                                <a asp-controller="Account"
                                       asp-action="Login"
                                       asp-area="Customer"
                                       class="btn btn-outline-success rounded-pill px-4">
                                    Login
                                </a>

                                @* <a asp-controller="Account"
                                       asp-action="ForgetPassword"
                                       asp-area="Customer"
                                       class="btn btn-outline-danger rounded-pill px-4">
                                    Forget Password
                                </a> *@

                            </div>
                        }

                    </div>
                </div>
            </nav>
        </div>
    </header>

    <partial name="_NotificationPartial" />

    @RenderBody()

    <a class="scroll-top disabled" href="#"><i class="fas fa-angle-up"></i></a>

    <footer class="section-text-white footer footer-links bg-darken">
        <div class="footer-body container">
            <div class="row">
                <div class="col-sm-6 col-lg-3">
                    <a class="footer-logo" href="/Customer/Home/Index">
                        <span class="logo-element">
                            <span class="logo-text text-uppercase">
                                <span>C</span>inema
                            </span>
                        </span>
                    </a>
                    <div class="footer-content">
                        <p class="footer-text">Cinema Booking System</p>
                        <p class="footer-text">Call us: (555) 555-0312</p>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <h5 class="footer-title text-uppercase">Movies</h5>
                    <ul class="list-unstyled list-wide footer-content">
                        <li><a class="content-link" href="/Customer/Movie/Index">All Movies</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <h5 class="footer-title text-uppercase">Account</h5>
                    <ul class="list-unstyled list-wide footer-content">
                        <li><a class="content-link" href="/Customer/Account/Login">Sign In</a></li>
                        <li><a class="content-link" href="/Customer/Account/Register">Sign Up</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <h5 class="footer-title text-uppercase">Follow</h5>
                    <ul class="list-wide footer-content list-inline">
                        <li class="list-inline-item"><a class="content-link" href="#"><i class="fab fa-twitter"></i></a></li>
                        <li class="list-inline-item"><a class="content-link" href="#"><i class="fab fa-facebook-f"></i></a></li>
                        <li class="list-inline-item"><a class="content-link" href="#"><i class="fab fa-instagram"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-copy">
            <div class="container">Copyright 2025 &copy; Cinema Booking. All rights reserved.</div>
        </div>
    </footer>

    <script src="~/customer/js/jquery-3.3.1.js"></script>
    <script src="~/customer/bootstrap/js/bootstrap.js"></script>
    <script src="~/customer/parallax.js/parallax.js"></script>
    <script src="~/customer/waypoints/jquery.waypoints.min.js"></script>
    <script src="~/customer/slick/slick.min.js"></script>
    <script src="~/customer/magnific-popup/jquery.magnific-popup.min.js"></script>
    <script src="~/customer/js/script.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>