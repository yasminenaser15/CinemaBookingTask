@using CinemaBookingTask.ViewModels;
@model UpsertMovieVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Movie</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" name="Id" value="@Model.Movie.Id" />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" placeholder="Name" name="Name" value="@Model.Movie.Name">
                </div>

                <div class="mb-3">
                    <div class="form-floating">
                        <textarea class="form-control" style="height:100px"
                                  placeholder="Description" name="Description">@Model.Movie.Description</textarea>
                        <label>Description</label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Price</label>
                    <input class="form-control" placeholder="Price" name="Price" value="@Model.Movie.Price">
                </div>

                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <select name="Status" class="form-select">
                        @if (Model.Movie.Status == "Available")
                        {
                            <option value="Available" selected>Available</option>
                            <option value="Coming Soon">Coming Soon</option>
                            <option value="Ended">Ended</option>
                        }
                        else if (Model.Movie.Status == "Coming Soon")
                        {
                            <option value="Available">Available</option>
                            <option value="Coming Soon" selected>Coming Soon</option>
                            <option value="Ended">Ended</option>
                        }
                        else
                        {
                            <option value="Available">Available</option>
                            <option value="Coming Soon">Coming Soon</option>
                            <option value="Ended" selected>Ended</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">DateTime</label>
                    <input type="datetime-local" class="form-control" name="DateTime"
                           value="@Model.Movie.DateTime.ToString("yyyy-MM-ddTHH:mm")">
                </div>

                <div class="mb-3">
                    <label class="form-label">Category</label>
                    <select name="CategoryId" class="form-select">
                        @foreach (var item in Model.Categories)
                        {
                            if (item.Id == Model.Movie.CategoryId)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>

                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cinema</label>
                    <select name="CinemaId" class="form-select">
                        @foreach (var item in Model.Cinemas)
                        {
                            if (item.Id == Model.Movie.CinemaId)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>

                    </div>

                    <div class="mb-3">
                        <label class="form-label">Actors</label>
                    <select name="actorIds" class="form-select" multiple>
                        @foreach (var item in Model.Actors)
                        {
                            if (Model.Movie.MovieActors != null &&
                                Model.Movie.MovieActors.Any(ma => ma.ActorId == item.Id))
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                        <small class="text-muted">Hold Ctrl to select multiple actors</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Update Main Image (optional)</label>
                        <input type="file" class="form-control" name="mainImg"
                               accept="image/*" onchange="previewImage(event)">
                        <small class="text-muted">Leave empty to keep current image</small>
                    </div>

                    <div class="mb-3">
                        <img id="preview"
                             src="~/images/movies/@Model.Movie.MainImg"
                             alt="Current Image"
                             style="max-width:200px; border:1px solid #ccc;
                        padding:5px; border-radius:10px;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Update Sub Images (optional)</label>
                        <input type="file" class="form-control" name="subImgs"
                               accept="image/*" multiple>
                        <small class="text-muted">Leave empty to keep current images</small>
                    </div>

                    <div class="mb-3 d-flex gap-2 flex-wrap">
                        @foreach (var item in Model.MovieSubImgs)
                        {
                            <img src="~/images/movies/movie_sub_imgs/@item.SubImg"
                                 style="max-width:150px; border:1px solid #ccc;
                            padding:5px; border-radius:10px;" />
                        }
                    </div>

                    <button type="submit" class="btn btn-warning">Update</button>
                    <a href="/Admin/Movie/Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>

    <script>
        function previewImage(event) {
            const preview = document.getElementById("preview");
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = e => preview.src = e.target.result;
                reader.readAsDataURL(file);
            }
        }
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }