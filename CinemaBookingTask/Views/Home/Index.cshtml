
@using CinemaBookingTask.Models
@using Microsoft.EntityFrameworkCore

<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card bg-transparent-50 overflow-hidden">
            <div class="card-header position-relative">
                <div class="position-relative z-index-2">
                    <div>
                        <h3 class="text-primary mb-1">Welcome to Cinema Booking Dashboard!</h3>
                        <p>Here's what's happening with your cinema today</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <span class="fas fa-film text-primary fa-2x"></span>
                </div>
                <div>
                    <h6 class="mb-1 text-700">Total Movies</h6>
                    <h4 class="mb-0 text-primary">@ViewBag.MoviesCount</h4>
                    <a href="/Movie/Index" class="fs--1">View all movies</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <span class="fas fa-video text-success fa-2x"></span>
                </div>
                <div>
                    <h6 class="mb-1 text-700">Total Cinemas</h6>
                    <h4 class="mb-0 text-success">@ViewBag.CinemasCount</h4>
                    <a href="/Cinema/Index" class="fs--1">View all cinemas</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <span class="fas fa-user text-warning fa-2x"></span>
                </div>
                <div>
                    <h6 class="mb-1 text-700">Total Actors</h6>
                    <h4 class="mb-0 text-warning">@ViewBag.ActorsCount</h4>
                    <a href="/Actor/Index" class="fs--1">View all actors</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <span class="fas fa-tags text-info fa-2x"></span>
                </div>
                <div>
                    <h6 class="mb-1 text-700">Total Categories</h6>
                    <h4 class="mb-0 text-info">@ViewBag.CategoriesCount</h4>
                    <a href="/Category/Index" class="fs--1">View all categories</a>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-flex gap-2 flex-wrap">
                    <a href="/Movie/Create" class="btn btn-primary">
                        <span class="fas fa-plus me-1"></span> Add Movie
                    </a>
                    <a href="/Cinema/Create" class="btn btn-success">
                        <span class="fas fa-plus me-1"></span> Add Cinema
                    </a>
                    <a href="/Actor/Create" class="btn btn-warning">
                        <span class="fas fa-plus me-1"></span> Add Actor
                    </a>
                    <a href="/Category/Create" class="btn btn-info">
                        <span class="fas fa-plus me-1"></span> Add Category
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Latest Movies</h5>
                <a href="/Movie/Index" class="btn btn-sm btn-falcon-default">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm fs--1 mb-0">
                        <thead class="bg-200 text-900">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Category</th>
                                <th>Cinema</th>
                                <th>DateTime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.LatestMovies as IEnumerable<Movie>)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>@item.Price.ToString("c")</td>
                                    <td><span class="badge text-bg-info">@item.Status</span></td>
                                    <td><span class="badge text-bg-success">@item.Category.Name</span></td>
                                    <td><span class="badge text-bg-primary">@item.Cinema.Name</span></td>
                                    <td>@item.DateTime.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>